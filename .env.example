#--------------------------------------------------------------------------
# Configurações do Ambiente da Aplicação
#--------------------------------------------------------------------------
APP_NAME="SEMARH Fiscaliza"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

#--------------------------------------------------------------------------
# Configuração do Banco de Dados (para Docker)
#--------------------------------------------------------------------------
# IMPORTANTE: Mantenha DB_HOST=db, pois é o nome do serviço do banco de dados na rede Docker.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=semarh_db
DB_USERNAME=semarh_user
DB_PASSWORD=secret

#--------------------------------------------------------------------------
# Configuração de Filas e Cache (Redis)
#--------------------------------------------------------------------------
# Mantenha REDIS_HOST=redis, que é o nome do serviço na rede Docker.
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379