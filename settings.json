{
  // Configurações do Workspace para o projeto SEMARH Fiscaliza

  // Define o perfil de terminal padrão para o Windows como "Git Bash".
  // Isso garante que os scripts .sh (como install.sh e gerenciar.sh)
  // funcionem corretamente sem que o desenvolvedor precise trocar manualmente o terminal.
  "terminal.integrated.defaultProfile.windows": "Git Bash",

  // Associações de arquivos para melhorar o realce de sintaxe.
  "files.associations": {
    ".env.example": "ini"
  },

  // Define o idioma de exibição do VS Code para Português (Brasil).
  "locale": "pt-br",

  // --- Configurações para Integração com Docker ---
  // As configurações abaixo instruem as extensões PHP a executarem
  // seus comandos dentro do contêiner Docker da aplicação.

  // Para a extensão PHP CS Fixer (ex: "junstyle.php-cs-fixer")
  "php-cs-fixer.docker": true,
  "php-cs-fixer.executablePath": "php-cs-fixer", // O nome do executável dentro do container
  "php-cs-fixer.onsave": true,
  "php-cs-fixer.allowRisky": true
}
